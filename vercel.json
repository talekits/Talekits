{
  "routes": [
    { "src": "^/$", "dest": "/landing.html" },
    { "src": "^/start$", "dest": "/signup.html" },
    { "src": "^/success$", "dest": "/success.html" },
    { "src": "^/dashboard$", "dest": "/dashboard.html" },
    { "src": "^/api/(.*)", "dest": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/schedule-stories",
      "schedule": "0 * * * *"
    }
  ],
  "functions": {
    "api/webhook.js": { "maxDuration": 300 },
    "api/generate-story.js": { "maxDuration": 300 },
    "api/generate-images.js": { "maxDuration": 300 },
    "api/generate-audio.js": { "maxDuration": 120 },
    "api/start-trial.js": { "maxDuration": 300 },
    "api/schedule-stories.js": { "maxDuration": 300 },
    "api/stress-test.js": { "maxDuration": 300 },
    "api/auth.js": { "maxDuration": 30 },
    "api/dashboard-api.js": { "maxDuration": 30 },
    "api/upload-char-photos.js": { "maxDuration": 60 },
    "api/story-archive.js": { "maxDuration": 30 },
    "api/pack-enquiry.js": { "maxDuration": 30 },
    "api/admin-generate.js": { "maxDuration": 300 }
  }
}
